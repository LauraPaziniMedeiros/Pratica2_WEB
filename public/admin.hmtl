<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Admin - Poções e Soluções</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header>
        <h1>Painel Administrativo</h1>
        <p>Gerenciamento de Inventário - Merigold</p>
        <a href="/" style="color:#e0e0e0">Voltar para a loja</a>
    </header>

    <main>
        <section>
            <h2>Cadastrar Nova Poção</h2>
            <form id="add-potion-form">
                <input type="text" id="nome" placeholder="Nome da Poção" required>
                <textarea id="descricao" placeholder="Descrição" required></textarea>
                <input type="url" id="imagem" placeholder="URL da Imagem" required>
                <input type="number" id="preco" placeholder="Preço (Moedas)" required>
                <button type="submit" class="btn-submit">Cadastrar Poção</button>
            </form>
        </section>

        <section>
            <h2>Poções Cadastradas</h2>
            <div id="admin-potions-container" class="products-grid">
                </div>
        </section>
    </main>

    <script src="admin.js"></script>
</body>
</html>